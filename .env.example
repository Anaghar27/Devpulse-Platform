# ── Reddit ───────────────────────────────────────────────────────────────────
# Reddit API client ID.
REDDIT_CLIENT_ID=your_reddit_client_id
# Reddit API client secret.
REDDIT_CLIENT_SECRET=your_reddit_client_secret
# Reddit API user agent string.
REDDIT_USER_AGENT=devpulse/1.0

# ── OpenRouter ───────────────────────────────────────────────────────────────
# OpenRouter API key for LLM access.
OPENROUTER_API_KEY=your_openrouter_api_key
# Primary model identifier for OpenRouter requests.
OPENROUTER_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1:free

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# PostgreSQL host.
# Use `localhost` for host-side scripts. Docker services override this to `postgres`.
POSTGRES_HOST=localhost
# PostgreSQL port.
POSTGRES_PORT=5432
# PostgreSQL database name.
POSTGRES_DB=devpulse
# PostgreSQL username.
POSTGRES_USER=devpulse_user
# PostgreSQL password.
POSTGRES_PASSWORD=your_postgres_password

# ── Kafka ────────────────────────────────────────────────────────────────────
# Kafka bootstrap servers for services running inside Docker.
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ── Redis ────────────────────────────────────────────────────────────────────
# Redis connection URL.
REDIS_URL=redis://redis:6379/0

# ── FastAPI Auth ─────────────────────────────────────────────────────────────
# JWT signing secret key. Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your_jwt_secret_key_generate_with_openssl_rand_hex_32
# JWT signing algorithm.
JWT_ALGORITHM=HS256
# JWT access token expiry in minutes.
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Internal API key for Airflow to FastAPI calls.
INTERNAL_API_KEY=your_internal_api_key

# ── dbt / DuckDB ─────────────────────────────────────────────────────────────
# Path to the DuckDB file produced by dbt (used by aggregator spike detection).
DBT_DUCKDB_PATH=transform/devpulse.duckdb

# ── Airflow ───────────────────────────────────────────────────────────────────
# Airflow Fernet key for encrypting connections and variables.
AIRFLOW__CORE__FERNET_KEY=your_fernet_key
# Shared Airflow webserver secret used to sign log access requests across all Airflow components.
AIRFLOW__WEBSERVER__SECRET_KEY=generate_with_openssl_rand_hex_32
# Airflow executor type.
AIRFLOW__CORE__EXECUTOR=LocalExecutor
